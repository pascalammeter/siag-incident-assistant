# SIAG Incident Management API — Environment Configuration Template
# Copy this file to .env.local (development) and fill in your values
# For production, use Vercel Environment Variables dashboard

# ============================================================================
# DATABASE CONFIGURATION
# ============================================================================

# Primary database connection string (Neon PostgreSQL)
# Format: postgresql://[user[:password]@][host[:port]][/database][?param=value]
# Get from: https://console.neon.tech/app/projects/{project}/connection
DATABASE_URL=postgresql://user:password@host.neon.tech/dbname?sslmode=require

# Direct URL for migrations (bypasses pgBouncer connection pooling)
# Required when using Neon pgBouncer for better performance
# Format: Same as DATABASE_URL but pointing directly to compute endpoint
DIRECT_URL=postgresql://user:password@host.neon.tech/dbname?sslmode=require

# ============================================================================
# API CONFIGURATION
# ============================================================================

# API Key for authentication (X-API-Key header)
# Development keys should start with: sk_test_
# Production keys should start with: sk_live_
# Keep this secret! Use strong random strings (32+ characters)
# Generate with: openssl rand -hex 16
API_KEY=sk_test_c827daa75b79f84c55d131665f03b346

# CORS allowed origins (comma-separated URLs)
# Development: http://localhost:3000
# Production: https://siag-incident-assistant.vercel.app
CORS_ORIGIN=http://localhost:3000

# ============================================================================
# ENVIRONMENT
# ============================================================================

# Node environment (development, test, production)
NODE_ENV=development

# Port for Express server (local development only)
# On Vercel, the function port is determined by Vercel runtime
PORT=3000

# ============================================================================
# LOGGING & DEBUG
# ============================================================================

# Enable debug logging for Prisma
# Set to "prisma:*" for detailed database logging
# Leave empty to disable (recommended for production)
DATABASE_DEBUG=

# Application log level (debug, info, warn, error)
LOG_LEVEL=info

# ============================================================================
# OPTIONAL: PDF EXPORT CONFIGURATION
# ============================================================================

# Puppeteer PDF generation timeout (milliseconds)
# Increase if PDF generation times out on large incidents
PDF_TIMEOUT_MS=30000

# Puppeteer launch arguments (advanced)
# Leave empty for defaults
# Example: --no-sandbox (required on some Linux systems)
PUPPETEER_ARGS=

# ============================================================================
# OPTIONAL: FEATURE FLAGS
# ============================================================================

# Enable API rate limiting (v1.2 feature)
# RATE_LIMITING_ENABLED=false

# Enable request logging middleware
# LOG_REQUESTS=false

# ============================================================================
# NOTES
# ============================================================================

# 1. DEVELOPMENT SETUP:
#    - Copy this file to .env.local
#    - Fill in DATABASE_URL and DIRECT_URL from Neon
#    - Generate a new API_KEY using: openssl rand -hex 16
#    - Set CORS_ORIGIN=http://localhost:3000
#    - Run: npm run dev:backend

# 2. PRODUCTION SETUP:
#    - Use Vercel Environment Variables dashboard
#    - Set NODE_ENV=production
#    - Use sk_live_ prefixed API_KEY
#    - Set CORS_ORIGIN=https://siag-incident-assistant.vercel.app
#    - Never commit .env files to git

# 3. DATABASE URL FORMAT:
#    From Neon Console:
#    - Node.js Connection String
#    - With SSL (sslmode=require)
#    - Example: postgresql://alice_neon:tHeCRgQh0r3L@ep-blue-dust-12345678.us-east-1.aws.neon.tech/neondb?sslmode=require

# 4. API KEY SECURITY:
#    - Generate using: openssl rand -hex 16
#    - Store only in environment variables (never in code)
#    - Rotate keys every 90 days (v1.2+)
#    - Use different keys for dev/staging/production
#    - Revoke compromised keys immediately

# 5. TROUBLESHOOTING:
#    If database connection fails:
#    - Verify DATABASE_URL is correct
#    - Check IP whitelist in Neon console
#    - Ensure SSL certificate is valid
#    - Try DIRECT_URL if CONNECTION_LIMIT_MODE is 'transaction'
#
#    If API fails to start:
#    - Check NODE_ENV setting
#    - Verify API_KEY format (minimum 32 chars)
#    - Check PORT is available (not in use)
#    - Review logs: npm run logs
